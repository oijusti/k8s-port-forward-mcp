{
  "name": "k8s-port-forward-mcp",
  "version": "1.0.3",
  "mcpName": "io.github.oijusti/k8s-port-forward-mcp",
  "description": "Kubernetes Port Forward — MCP Server: port-forward Kubernetes services with terminal integration",
  "main": "dist/index.js",
  "bin": {
    "k8s-port-forward-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "npm run build:js",
    "build:js": "esbuild src/index.ts --bundle --packages=external --platform=node --format=esm --target=node18 --minify --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.{ts,js,json}\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\" \"*.json\"",
    "prepublishOnly": "npm run build",
    "publish:npm:dry": "npm publish --dry-run",
    "publish:npm": "npm publish"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "kubernetes",
    "k8s",
    "port-forward",
    "terminal",
    "oijusti"
  ],
  "author": "oijusti",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oijusti/k8s-port-forward-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/oijusti/k8s-port-forward-mcp/issues"
  },
  "homepage": "https://github.com/oijusti/k8s-port-forward-mcp#readme",
  "files": [
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.0",
    "prettier": "^3.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
